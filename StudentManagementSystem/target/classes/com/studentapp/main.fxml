<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #1a1f36;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studentapp.Controller">

    <!-- ── TOP BAR ─────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #2c3e8c; -fx-padding: 14 20 14 20;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Student Management System" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;                            -fx-background-radius: 6; -fx-padding: 6 18 6 18;                            -fx-font-size: 12px; -fx-cursor: hand;" text="Logout" />
        </HBox>
    </top>

    <!-- ── LEFT PANEL – Form ───────────────────── -->
    <left>
        <VBox alignment="TOP_LEFT" spacing="12" style="-fx-background-color: #242b4d; -fx-padding: 24 20 24 20;                      -fx-pref-width: 280px;">

            <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Student Details" />

            <Separator style="-fx-background-color: #3d4a7a;" />

            <!-- Name -->
            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11px; -fx-font-weight: bold;" text="Name" />
            <TextField fx:id="txtName" promptText="Full name" style="-fx-background-color: #1a1f36; -fx-text-fill: white;                               -fx-prompt-text-fill: #4a5568; -fx-border-color: #3d4a7a;                               -fx-border-radius: 5; -fx-background-radius: 5;                               -fx-padding: 8 10 8 10;" />

            <!-- Course -->
            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11px; -fx-font-weight: bold;" text="Course" />
            <TextField fx:id="txtCourse" promptText="e.g. BS Computer Science" style="-fx-background-color: #1a1f36; -fx-text-fill: white;                               -fx-prompt-text-fill: #4a5568; -fx-border-color: #3d4a7a;                               -fx-border-radius: 5; -fx-background-radius: 5;                               -fx-padding: 8 10 8 10;" />

            <!-- Year Level -->
            <Label style="-fx-text-fill: #a0aec0; -fx-font-size: 11px; -fx-font-weight: bold;" text="Year Level" />
            <ChoiceBox fx:id="cbYear" maxWidth="Infinity" style="-fx-background-color: #1a1f36; -fx-border-color: #3d4a7a;                               -fx-border-radius: 5; -fx-background-radius: 5;" />

            <Separator style="-fx-background-color: #3d4a7a;" />

            <!-- Buttons -->
            <Button maxWidth="Infinity" onAction="#addStudent" style="-fx-background-color: #27ae60; -fx-text-fill: white;                            -fx-background-radius: 6; -fx-padding: 10 0 10 0;                            -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="Add Student" />

            <Button maxWidth="Infinity" onAction="#updateStudent" style="-fx-background-color: #2980b9; -fx-text-fill: white;                            -fx-background-radius: 6; -fx-padding: 10 0 10 0;                            -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="Update Student" />

            <Button maxWidth="Infinity" onAction="#deleteStudent" style="-fx-background-color: #e74c3c; -fx-text-fill: white;                            -fx-background-radius: 6; -fx-padding: 10 0 10 0;                            -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="Delete Student" />

            <Button maxWidth="Infinity" onAction="#clearFields" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;                            -fx-background-radius: 6; -fx-padding: 10 0 10 0;                            -fx-font-size: 13px; -fx-cursor: hand;" text="Clear Fields" />

            <Pane VBox.vgrow="ALWAYS" />

            <!-- Status label -->
            <Label fx:id="lblStatus" maxWidth="240" style="-fx-font-size: 12px;" text="" wrapText="true" />

        </VBox>
    </left>

    <!-- ── CENTER – TableView ──────────────────── -->
    <center>
        <VBox spacing="10" style="-fx-padding: 24 20 24 20;">
            <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="All Students" />

            <TableView fx:id="table" style="-fx-background-color: #242b4d; -fx-border-color: #3d4a7a;                               -fx-border-radius: 6; -fx-background-radius: 6;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="55" text="ID" />
                    <TableColumn fx:id="colName" prefWidth="200" text="Name" />
                    <TableColumn fx:id="colCourse" prefWidth="220" text="Course" />
                    <TableColumn fx:id="colYear" prefWidth="110" text="Year Level" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #4a5568;" text="No records found. Add a student to get started." />
                </placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
